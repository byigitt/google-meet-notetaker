# === Required ===
OPENAI_API_KEY=sk-your-api-key-here

# === Bot Settings ===
BOT_NAME=AI Notetaker
PORT=3000

# === Caption Language ===
# Must match the language name in Google Meet (for example: English, Turkish, German, French)
CAPTION_LANGUAGE=English

# === Transcription Strategy ===
# "captions" = Scrape Google Meet captions (free; no extra API key required)
# "whisper"  = Record the meeting and transcribe it with Whisper at the end
TRANSCRIPTION_STRATEGY=captions

# === Whisper (required only when strategy=whisper and different from OPENAI_API_KEY) ===
# For OpenAI-compatible providers such as Groq:
# WHISPER_API_KEY=gsk_your-groq-key-here
# WHISPER_BASE_URL=https://api.groq.com/openai/v1
# WHISPER_MODEL=whisper-large-v3

# === Debug / Development ===
# Keep the audio file and save it to recordings/:
# WHISPER_KEEP_AUDIO=true

# === Google Account (optional) ===
# GOOGLE_EMAIL=your-email@gmail.com
# GOOGLE_PASSWORD=your-password
