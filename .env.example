# === Zorunlu ===
OPENAI_API_KEY=sk-your-api-key-here

# === Bot Ayarları ===
BOT_NAME=AI Notetaker
PORT=3000

# === Altyazı Dili ===
# Google Meet'teki dil ismiyle eşleşmeli (ör: Turkish, English, German, French)
CAPTION_LANGUAGE=Turkish

# === Transkripsiyon Stratejisi ===
# "captions" = Google Meet altyazılarını scrape et (ücretsiz, API key gerektirmez)
# "deepgram" = Deepgram ile real-time ses transkripsiyonu (daha kaliteli)
# "whisper"  = Toplantıyı kaydet, sonunda OpenAI Whisper API ile transkript al
TRANSCRIPTION_STRATEGY=captions

# === Deepgram (sadece strategy=deepgram ise gerekli) ===
DEEPGRAM_API_KEY=your-deepgram-key-here

# === Whisper (sadece strategy=whisper ise gerekli) ===
# WHISPER_MODEL=whisper-1
# Farklı provider için (ör: Groq):
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_your-groq-key-here

# === Google Hesabı (opsiyonel) ===
# GOOGLE_EMAIL=your-email@gmail.com
# GOOGLE_PASSWORD=your-password
