{
  "name": "google-meet-notetaker",
  "version": "1.0.0",
  "description": "AI-powered Google Meet notetaker - joins meetings, transcribes, and summarizes",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "dev:cli": "tsx --watch src/cli.ts",
    "cli": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:cli": "node dist/cli.js"
  },
  "dependencies": {
    "@deepgram/sdk": "^3.11.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.78.1",
    "patchright": "^1.57.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
